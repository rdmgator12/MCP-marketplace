  "rating_system": {
    "hipaa_levels": {
      "5": {
        "badge": "HIPAA-Ready",
        "color": "green",
        "description": "Full BAA, AES-256, audit logging, RBAC, pen-tested",
        "use_case": "Production clinical environments with PHI"
      },
      "4": {
        "badge": "HIPAA-Aware",
        "color": "blue",
        "description": "Encryption in transit, no PHI storage, privacy-by-design",
        "use_case": "Clinical reference, no PHI handling"
      },
      "3": {
        "badge": "De-identified Safe",
        "color": "yellow",
        "description": "Aggregate/de-identified data only",
        "use_case": "Analytics, population health"
      },
      "2": {
        "badge": "Reference Only",
        "color": "white",
        "description": "Public data sources only (FDA, NLM, CMS)",
        "use_case": "Education, reference lookup"
      },
      "1": {
        "badge": "Unvetted",
        "color": "gray",
        "description": "Not yet assessed",
        "use_case": "Use at own risk"
      }
    },
    "clinical_validity": {
      "A": "Clinically Validated - evidence-based, peer-reviewed, physician-endorsed",
      "B": "Clinically Informed - built with clinical input, follows guidelines",
      "C": "Operationally Useful - administrative/financial tools, not clinical",
      "D": "Experimental - research-stage, community-developed"
    }
